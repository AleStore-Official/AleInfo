name: Generate Sitemap

on:
  push:
    branches: [ main ]
  schedule:
    - cron: "0 */12 * * *"

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v3

      - name: Generate sitemap
        run: |
          repos=(
            "AleCAPTCHA"
            "AleRegister"
            "AleLogin"
            "AleCassier"
            "AleInfo"
            "AleCrypt"
            "AlePortal"
            "AleStore"
            "AleDJ"
            "AleConfirm"
          )

          echo '<?xml version="1.0" encoding="UTF-8"?>' > sitemap.xml
          echo '<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">' >> sitemap.xml

          for repo in "${repos[@]}"; do
            api="https://api.github.com/repos/AleStore-Official/$repo/git/trees/main?recursive=1"

            curl -s -H "User-Agent: AleStoreBot" "$api" \
            | jq -r '.tree[] | select(.path | endswith(".html")) | .path' \
            | while read file; do
                url="https://alestore-official.github.io/$repo/$file"
                echo "  <url><loc>$url</loc><changefreq>weekly</changefreq><priority>0.8</priority></url>" >> sitemap.xml
              done
          done

          echo '</urlset>' >> sitemap.xml

      - name: Commit sitemap
        run: |
          git config user.name "AleStore Bot"
          git config user.email "bot@alestore.com"
          git add sitemap.xml
          git commit -m "Update sitemap" || echo "No changes"
          git push